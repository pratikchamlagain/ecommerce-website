PORT=5000
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/watchmatrix_prod?schema=public"
JWT_ACCESS_SECRET="replace-with-strong-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-strong-secret"
CORS_ORIGIN="https://watchmatrix.example"

# Optional security hardening overrides
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
CHAT_CREATE_RATE_LIMIT_WINDOW_MS=60000
CHAT_CREATE_RATE_LIMIT_MAX=12
CHAT_MESSAGE_WINDOW_MS=10000
CHAT_MESSAGE_MAX_PER_WINDOW=6
CHAT_BLOCKED_TERMS="scam,fraud,phishing,otp,password"
CHAT_MAX_REPEAT_CHARS=12

# Payment provider config
FRONTEND_BASE_URL="https://watchmatrix.example"
BACKEND_BASE_URL="https://api.watchmatrix.example"

ESEWA_PRODUCT_CODE="EPAYTEST"
ESEWA_SECRET_KEY="replace-with-esewa-secret"
ESEWA_PAYMENT_URL="https://epay.esewa.com.np/api/epay/main/v2/form"

KHALTI_SECRET_KEY="replace-with-khalti-secret-key"
KHALTI_INITIATE_URL="https://khalti.com/api/v2/epayment/initiate/"
KHALTI_LOOKUP_URL="https://khalti.com/api/v2/epayment/lookup/"
